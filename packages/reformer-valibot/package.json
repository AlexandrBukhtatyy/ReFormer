{
  "name": "@reformer/valibot",
  "version": "1.0.0",
  "description": "Valibot schema adapter for ReFormer forms",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "reformer",
    "forms",
    "valibot",
    "validation",
    "adapter",
    "schema",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Alexandr Bukhtatyy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexandrBukhtatyy/ReFormer.git"
  },
  "homepage": "https://alexandrbukhtatyy.github.io/ReFormer/",
  "bugs": {
    "url": "https://github.com/AlexandrBukhtatyy/ReFormer/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@reformer/core": "^1.0.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@reformer/core": "*",
    "valibot": "^1.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.8"
  }
}
