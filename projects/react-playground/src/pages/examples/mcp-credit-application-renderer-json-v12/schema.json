{
  "version": "1.0",
  "root": {
    "selector": "form-root",
    "component": "FormRoot",
    "children": [
      {
        "selector": "step-1",
        "component": "Section",
        "componentProps": { "title": "Шаг 1. Кредит", "className": "space-y-4" },
        "children": [
          { "model": "loanType", "component": "Select", "componentProps": { "label": "Тип кредита", "testId": "loanType", "options": "LOAN_TYPES" } },
          { "model": "loanAmount", "component": "Input", "componentProps": { "label": "Сумма кредита (руб)", "type": "number", "testId": "loanAmount", "placeholder": "Введите сумму" } },
          { "model": "loanTerm", "component": "Input", "componentProps": { "label": "Срок кредита (месяцев)", "type": "number", "testId": "loanTerm" } },
          { "model": "loanPurpose", "component": "Textarea", "componentProps": { "label": "Цель кредита", "testId": "loanPurpose", "placeholder": "Опишите цель", "rows": 3 } },
          {
            "selector": "mortgage-block",
            "component": "Section",
            "componentProps": { "title": "Ипотека", "className": "space-y-4 border-t pt-4" },
            "children": [
              { "model": "propertyValue", "component": "Input", "componentProps": { "label": "Стоимость недвижимости (руб)", "type": "number", "testId": "propertyValue" } },
              { "model": "initialPayment", "component": "Input", "componentProps": { "label": "Первоначальный взнос (руб) — авто", "type": "number", "testId": "initialPayment", "readOnly": true } }
            ]
          },
          {
            "selector": "car-block",
            "component": "Section",
            "componentProps": { "title": "Автокредит", "className": "space-y-4 border-t pt-4" },
            "children": [
              { "model": "carBrand", "component": "Input", "componentProps": { "label": "Марка автомобиля", "testId": "carBrand" } },
              { "model": "carModel", "component": "Input", "componentProps": { "label": "Модель автомобиля", "testId": "carModel" } },
              { "model": "carYear", "component": "Input", "componentProps": { "label": "Год выпуска", "type": "number", "testId": "carYear" } },
              { "model": "carPrice", "component": "Input", "componentProps": { "label": "Стоимость автомобиля (руб)", "type": "number", "testId": "carPrice" } }
            ]
          }
        ]
      },
      {
        "selector": "step-2",
        "component": "Section",
        "componentProps": { "title": "Шаг 2. Личные данные", "className": "space-y-4" },
        "children": [
          { "model": "personalData.lastName", "component": "Input", "componentProps": { "label": "Фамилия", "testId": "lastName" } },
          { "model": "personalData.firstName", "component": "Input", "componentProps": { "label": "Имя", "testId": "firstName" } },
          { "model": "personalData.middleName", "component": "Input", "componentProps": { "label": "Отчество", "testId": "middleName" } },
          { "model": "personalData.birthDate", "component": "Input", "componentProps": { "label": "Дата рождения", "type": "date", "testId": "birthDate" } },
          { "model": "personalData.gender", "component": "Select", "componentProps": { "label": "Пол", "testId": "gender", "options": "GENDERS" } },
          { "model": "personalData.birthPlace", "component": "Input", "componentProps": { "label": "Место рождения", "testId": "birthPlace" } },
          { "model": "fullName", "component": "Input", "componentProps": { "label": "Полное имя — авто", "testId": "fullName", "readOnly": true } },
          { "model": "age", "component": "Input", "componentProps": { "label": "Возраст — авто", "type": "number", "testId": "age", "readOnly": true } },
          { "model": "passportData.series", "component": "Input", "componentProps": { "label": "Серия паспорта", "testId": "passportSeries", "placeholder": "12 34" } },
          { "model": "passportData.number", "component": "Input", "componentProps": { "label": "Номер паспорта", "testId": "passportNumber", "placeholder": "123456" } },
          { "model": "passportData.issueDate", "component": "Input", "componentProps": { "label": "Дата выдачи", "type": "date", "testId": "passportIssueDate" } },
          { "model": "passportData.issuedBy", "component": "Input", "componentProps": { "label": "Кем выдан", "testId": "passportIssuedBy" } },
          { "model": "passportData.departmentCode", "component": "Input", "componentProps": { "label": "Код подразделения", "testId": "passportDepartmentCode", "placeholder": "123-456" } },
          { "model": "inn", "component": "Input", "componentProps": { "label": "ИНН", "testId": "inn", "placeholder": "123456789012" } },
          { "model": "snils", "component": "Input", "componentProps": { "label": "СНИЛС", "testId": "snils", "placeholder": "123-456-789 00" } }
        ]
      },
      {
        "selector": "step-3",
        "component": "Section",
        "componentProps": { "title": "Шаг 3. Контакты", "className": "space-y-4" },
        "children": [
          { "model": "phoneMain", "component": "Input", "componentProps": { "label": "Основной телефон", "testId": "phoneMain", "placeholder": "+7 (___) ___-__-__" } },
          { "model": "phoneAdditional", "component": "Input", "componentProps": { "label": "Дополнительный телефон", "testId": "phoneAdditional" } },
          { "model": "email", "component": "Input", "componentProps": { "label": "Email", "type": "email", "testId": "email", "placeholder": "name@example.com" } },
          { "model": "emailAdditional", "component": "Input", "componentProps": { "label": "Дополнительный email", "type": "email", "testId": "emailAdditional" } },
          { "model": "registrationAddress.region", "component": "Input", "componentProps": { "label": "Регион регистрации", "testId": "regRegion" } },
          { "model": "registrationAddress.city", "component": "Input", "componentProps": { "label": "Город", "testId": "regCity" } },
          { "model": "registrationAddress.street", "component": "Input", "componentProps": { "label": "Улица", "testId": "regStreet" } },
          { "model": "registrationAddress.house", "component": "Input", "componentProps": { "label": "Дом", "testId": "regHouse" } },
          { "model": "registrationAddress.apartment", "component": "Input", "componentProps": { "label": "Квартира", "testId": "regApartment" } },
          { "model": "registrationAddress.postalCode", "component": "Input", "componentProps": { "label": "Индекс", "testId": "regPostalCode", "placeholder": "000000" } },
          { "model": "sameAsRegistration", "component": "Checkbox", "componentProps": { "label": "Адрес проживания совпадает с адресом регистрации", "testId": "sameAsRegistration" } },
          {
            "selector": "residence-block",
            "component": "Section",
            "componentProps": { "title": "Адрес проживания", "className": "space-y-4 border-t pt-4" },
            "children": [
              { "model": "residenceAddress.region", "component": "Input", "componentProps": { "label": "Регион проживания", "testId": "resRegion" } },
              { "model": "residenceAddress.city", "component": "Input", "componentProps": { "label": "Город", "testId": "resCity" } },
              { "model": "residenceAddress.street", "component": "Input", "componentProps": { "label": "Улица", "testId": "resStreet" } },
              { "model": "residenceAddress.house", "component": "Input", "componentProps": { "label": "Дом", "testId": "resHouse" } },
              { "model": "residenceAddress.apartment", "component": "Input", "componentProps": { "label": "Квартира", "testId": "resApartment" } },
              { "model": "residenceAddress.postalCode", "component": "Input", "componentProps": { "label": "Индекс", "testId": "resPostalCode" } }
            ]
          }
        ]
      },
      {
        "selector": "step-4",
        "component": "Section",
        "componentProps": { "title": "Шаг 4. Занятость", "className": "space-y-4" },
        "children": [
          { "model": "employmentStatus", "component": "Select", "componentProps": { "label": "Статус занятости", "testId": "employmentStatus", "options": "EMPLOYMENT_STATUSES" } },
          {
            "selector": "employed-block",
            "component": "Section",
            "componentProps": { "title": "Работа по найму", "className": "space-y-4 border-t pt-4" },
            "children": [
              { "model": "companyName", "component": "Input", "componentProps": { "label": "Название компании", "testId": "companyName" } },
              { "model": "companyInn", "component": "Input", "componentProps": { "label": "ИНН компании", "testId": "companyInn" } },
              { "model": "companyPhone", "component": "Input", "componentProps": { "label": "Телефон компании", "testId": "companyPhone" } },
              { "model": "companyAddress", "component": "Input", "componentProps": { "label": "Адрес компании", "testId": "companyAddress" } },
              { "model": "position", "component": "Input", "componentProps": { "label": "Должность", "testId": "position" } }
            ]
          },
          {
            "selector": "self-employed-block",
            "component": "Section",
            "componentProps": { "title": "ИП / Самозанятость", "className": "space-y-4 border-t pt-4" },
            "children": [
              { "model": "businessType", "component": "Input", "componentProps": { "label": "Тип бизнеса", "testId": "businessType" } },
              { "model": "businessInn", "component": "Input", "componentProps": { "label": "ИНН ИП", "testId": "businessInn" } },
              { "model": "businessActivity", "component": "Textarea", "componentProps": { "label": "Вид деятельности", "testId": "businessActivity", "rows": 2 } }
            ]
          },
          { "model": "workExperienceTotal", "component": "Input", "componentProps": { "label": "Общий стаж (мес)", "type": "number", "testId": "workExperienceTotal" } },
          { "model": "workExperienceCurrent", "component": "Input", "componentProps": { "label": "Стаж на текущем месте (мес)", "type": "number", "testId": "workExperienceCurrent" } },
          { "model": "monthlyIncome", "component": "Input", "componentProps": { "label": "Ежемесячный доход (руб)", "type": "number", "testId": "monthlyIncome" } },
          { "model": "additionalIncome", "component": "Input", "componentProps": { "label": "Дополнительный доход (руб)", "type": "number", "testId": "additionalIncome" } },
          { "model": "additionalIncomeSource", "component": "Input", "componentProps": { "label": "Источник доп. дохода", "testId": "additionalIncomeSource" } },
          { "model": "totalIncome", "component": "Input", "componentProps": { "label": "Общий доход (руб) — авто", "type": "number", "testId": "totalIncome", "readOnly": true } },
          { "model": "interestRate", "component": "Input", "componentProps": { "label": "Процентная ставка (%) — авто", "type": "number", "testId": "interestRate", "readOnly": true } },
          { "model": "monthlyPayment", "component": "Input", "componentProps": { "label": "Ежемесячный платёж (руб) — авто", "type": "number", "testId": "monthlyPayment", "readOnly": true } },
          { "model": "paymentToIncomeRatio", "component": "Input", "componentProps": { "label": "Платёж/доход (%) — авто", "type": "number", "testId": "paymentToIncomeRatio", "readOnly": true } }
        ]
      },
      {
        "selector": "step-5",
        "component": "Section",
        "componentProps": { "title": "Шаг 5. Дополнительно", "className": "space-y-4" },
        "children": [
          { "model": "maritalStatus", "component": "Select", "componentProps": { "label": "Семейное положение", "testId": "maritalStatus", "options": "MARITAL_STATUSES" } },
          { "model": "dependents", "component": "Input", "componentProps": { "label": "Количество иждивенцев", "type": "number", "testId": "dependents" } },
          { "model": "education", "component": "Select", "componentProps": { "label": "Образование", "testId": "education", "options": "EDUCATION_LEVELS" } },
          { "model": "hasProperty", "component": "Checkbox", "componentProps": { "label": "У меня есть имущество", "testId": "hasProperty" } },
          { "model": "hasExistingLoans", "component": "Checkbox", "componentProps": { "label": "У меня есть другие кредиты", "testId": "hasExistingLoans" } },
          { "model": "hasCoBorrower", "component": "Checkbox", "componentProps": { "label": "Добавить созаемщика", "testId": "hasCoBorrower" } }
        ]
      },
      {
        "selector": "step-6",
        "component": "Section",
        "componentProps": { "title": "Шаг 6. Подтверждение", "className": "space-y-4" },
        "children": [
          { "model": "agreePersonalData", "component": "Checkbox", "componentProps": { "label": "Согласие на обработку персональных данных", "testId": "agreePersonalData" } },
          { "model": "agreeCreditHistory", "component": "Checkbox", "componentProps": { "label": "Согласие на проверку кредитной истории", "testId": "agreeCreditHistory" } },
          { "model": "agreeMarketing", "component": "Checkbox", "componentProps": { "label": "Согласие на маркетинговые материалы", "testId": "agreeMarketing" } },
          { "model": "agreeTerms", "component": "Checkbox", "componentProps": { "label": "Согласие с условиями кредитования", "testId": "agreeTerms" } },
          { "model": "confirmAccuracy", "component": "Checkbox", "componentProps": { "label": "Подтверждаю точность введённых данных", "testId": "confirmAccuracy" } },
          { "model": "electronicSignature", "component": "Input", "componentProps": { "label": "Код из СМС", "testId": "electronicSignature", "placeholder": "123456" } }
        ]
      }
    ]
  }
}
