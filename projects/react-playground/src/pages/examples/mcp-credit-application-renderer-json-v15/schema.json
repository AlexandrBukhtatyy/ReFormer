{
  "version": "1.0",
  "root": {
    "selector": "form-root",
    "component": "FormRoot",
    "componentProps": {
      "wizardConfig": "WIZARD_CONFIG",
      "onSubmit": "HANDLE_SUBMIT"
    },
    "children": [
      {
        "selector": "step1-body",
        "component": "Box",
        "componentProps": { "className": "space-y-4" },
        "children": [
          { "model": "loanType", "component": "Select", "componentProps": { "label": "Тип кредита", "placeholder": "Выберите тип кредита", "options": "LOAN_TYPES", "testId": "loanType" } },
          { "model": "loanAmount", "component": "Input", "componentProps": { "label": "Сумма кредита (₽)", "type": "number", "placeholder": "Введите сумму", "testId": "loanAmount" } },
          { "model": "loanTerm", "component": "Input", "componentProps": { "label": "Срок кредита (месяцев)", "type": "number", "placeholder": "Введите срок", "testId": "loanTerm" } },
          { "model": "loanPurpose", "component": "Textarea", "componentProps": { "label": "Цель кредита", "placeholder": "Опишите, на что планируете потратить средства", "rows": 3, "testId": "loanPurpose" } },
          {
            "selector": "mortgage-section",
            "component": "Section",
            "componentProps": { "title": "Ипотека", "className": "space-y-3" },
            "children": [
              { "model": "propertyValue", "component": "Input", "componentProps": { "label": "Стоимость недвижимости (₽)", "type": "number", "placeholder": "Введите стоимость", "testId": "propertyValue" } },
              { "model": "initialPayment", "component": "Input", "componentProps": { "label": "Первоначальный взнос (₽)", "type": "number", "readOnly": true, "testId": "initialPayment" } }
            ]
          },
          {
            "selector": "car-section",
            "component": "Section",
            "componentProps": { "title": "Автокредит", "className": "space-y-3" },
            "children": [
              { "model": "carBrand", "component": "Input", "componentProps": { "label": "Марка автомобиля", "placeholder": "Например: Toyota", "testId": "carBrand" } },
              { "model": "carModel", "component": "Input", "componentProps": { "label": "Модель автомобиля", "placeholder": "Например: Camry", "testId": "carModel" } },
              { "model": "carYear", "component": "Input", "componentProps": { "label": "Год выпуска", "type": "number", "placeholder": "2020", "testId": "carYear" } },
              { "model": "carPrice", "component": "Input", "componentProps": { "label": "Стоимость автомобиля (₽)", "type": "number", "placeholder": "Введите стоимость", "testId": "carPrice" } }
            ]
          },
          {
            "selector": "computed-summary-step1",
            "component": "Section",
            "componentProps": { "title": "Расчёт", "className": "space-y-3" },
            "children": [
              { "model": "interestRate", "component": "Input", "componentProps": { "label": "Процентная ставка (%)", "type": "number", "readOnly": true, "testId": "interestRate" } },
              { "model": "monthlyPayment", "component": "Input", "componentProps": { "label": "Ежемесячный платёж (₽)", "type": "number", "readOnly": true, "testId": "monthlyPayment" } }
            ]
          }
        ]
      },
      {
        "selector": "step2-body",
        "component": "Box",
        "componentProps": { "className": "space-y-4" },
        "children": [
          {
            "selector": "personal-data-section",
            "component": "Section",
            "componentProps": { "title": "Личные данные", "className": "space-y-3" },
            "children": [
              { "model": "personalData.lastName", "component": "Input", "componentProps": { "label": "Фамилия", "placeholder": "Введите фамилию", "testId": "lastName" } },
              { "model": "personalData.firstName", "component": "Input", "componentProps": { "label": "Имя", "placeholder": "Введите имя", "testId": "firstName" } },
              { "model": "personalData.middleName", "component": "Input", "componentProps": { "label": "Отчество", "placeholder": "Введите отчество", "testId": "middleName" } },
              { "model": "personalData.birthDate", "component": "Input", "componentProps": { "label": "Дата рождения", "type": "date", "testId": "birthDate" } },
              { "model": "personalData.gender", "component": "RadioGroup", "componentProps": { "label": "Пол", "options": "GENDERS", "testId": "gender" } },
              { "model": "personalData.birthPlace", "component": "Input", "componentProps": { "label": "Место рождения", "placeholder": "Введите место рождения", "testId": "birthPlace" } },
              { "model": "fullName", "component": "Input", "componentProps": { "label": "Полное имя", "readOnly": true, "testId": "fullName" } },
              { "model": "age", "component": "Input", "componentProps": { "label": "Возраст (лет)", "type": "number", "readOnly": true, "testId": "age" } }
            ]
          },
          {
            "selector": "passport-section",
            "component": "Section",
            "componentProps": { "title": "Паспортные данные", "className": "space-y-3" },
            "children": [
              { "model": "passportData.series", "component": "InputMask", "componentProps": { "label": "Серия паспорта", "mask": "99 99", "placeholder": "12 34", "testId": "passportSeries" } },
              { "model": "passportData.number", "component": "InputMask", "componentProps": { "label": "Номер паспорта", "mask": "999999", "placeholder": "123456", "testId": "passportNumber" } },
              { "model": "passportData.issueDate", "component": "Input", "componentProps": { "label": "Дата выдачи", "type": "date", "testId": "passportIssueDate" } },
              { "model": "passportData.issuedBy", "component": "Input", "componentProps": { "label": "Кем выдан", "placeholder": "Введите название органа", "testId": "passportIssuedBy" } },
              { "model": "passportData.departmentCode", "component": "InputMask", "componentProps": { "label": "Код подразделения", "mask": "999-999", "placeholder": "123-456", "testId": "passportDepartmentCode" } }
            ]
          },
          {
            "selector": "documents-section",
            "component": "Section",
            "componentProps": { "title": "Документы", "className": "space-y-3" },
            "children": [
              { "model": "inn", "component": "InputMask", "componentProps": { "label": "ИНН", "mask": "999999999999", "placeholder": "123456789012", "testId": "inn" } },
              { "model": "snils", "component": "InputMask", "componentProps": { "label": "СНИЛС", "mask": "999-999-999 99", "placeholder": "123-456-789 00", "testId": "snils" } }
            ]
          }
        ]
      },
      {
        "selector": "step3-body",
        "component": "Box",
        "componentProps": { "className": "space-y-4" },
        "children": [
          {
            "selector": "phones-section",
            "component": "Section",
            "componentProps": { "title": "Телефоны и email", "className": "space-y-3" },
            "children": [
              { "model": "phoneMain", "component": "InputMask", "componentProps": { "label": "Основной телефон", "mask": "+7 (999) 999-99-99", "placeholder": "+7 (___) ___-__-__", "testId": "phoneMain" } },
              { "model": "phoneAdditional", "component": "InputMask", "componentProps": { "label": "Дополнительный телефон", "mask": "+7 (999) 999-99-99", "placeholder": "+7 (___) ___-__-__", "testId": "phoneAdditional" } },
              { "model": "email", "component": "Input", "componentProps": { "label": "Email", "type": "email", "placeholder": "example@mail.com", "testId": "email" } },
              { "model": "emailAdditional", "component": "Input", "componentProps": { "label": "Дополнительный email", "type": "email", "placeholder": "example@mail.com", "testId": "emailAdditional" } }
            ]
          },
          {
            "selector": "registration-address-section",
            "component": "Section",
            "componentProps": { "title": "Адрес регистрации", "className": "space-y-3" },
            "children": [
              { "model": "registrationAddress.region", "component": "Input", "componentProps": { "label": "Регион", "placeholder": "Введите регион", "testId": "registrationRegion" } },
              { "model": "registrationAddress.city", "component": "Input", "componentProps": { "label": "Город", "placeholder": "Введите город", "testId": "registrationCity" } },
              { "model": "registrationAddress.street", "component": "Input", "componentProps": { "label": "Улица", "placeholder": "Введите улицу", "testId": "registrationStreet" } },
              { "model": "registrationAddress.house", "component": "Input", "componentProps": { "label": "Дом", "placeholder": "№", "testId": "registrationHouse" } },
              { "model": "registrationAddress.apartment", "component": "Input", "componentProps": { "label": "Квартира", "placeholder": "№", "testId": "registrationApartment" } },
              { "model": "registrationAddress.postalCode", "component": "InputMask", "componentProps": { "label": "Индекс", "mask": "999999", "placeholder": "000000", "testId": "registrationPostalCode" } }
            ]
          },
          {
            "selector": "residence-toggle-section",
            "component": "Section",
            "componentProps": { "title": "Адрес проживания", "className": "space-y-3" },
            "children": [
              { "model": "sameAsRegistration", "component": "Checkbox", "componentProps": { "label": "Адрес проживания совпадает с адресом регистрации", "testId": "sameAsRegistration" } }
            ]
          },
          {
            "selector": "residence-address-section",
            "component": "Section",
            "componentProps": { "title": "Адрес проживания (полный)", "className": "space-y-3" },
            "children": [
              { "model": "residenceAddress.region", "component": "Input", "componentProps": { "label": "Регион", "placeholder": "Введите регион", "testId": "residenceRegion" } },
              { "model": "residenceAddress.city", "component": "Input", "componentProps": { "label": "Город", "placeholder": "Введите город", "testId": "residenceCity" } },
              { "model": "residenceAddress.street", "component": "Input", "componentProps": { "label": "Улица", "placeholder": "Введите улицу", "testId": "residenceStreet" } },
              { "model": "residenceAddress.house", "component": "Input", "componentProps": { "label": "Дом", "placeholder": "№", "testId": "residenceHouse" } },
              { "model": "residenceAddress.apartment", "component": "Input", "componentProps": { "label": "Квартира", "placeholder": "№", "testId": "residenceApartment" } },
              { "model": "residenceAddress.postalCode", "component": "InputMask", "componentProps": { "label": "Индекс", "mask": "999999", "placeholder": "000000", "testId": "residencePostalCode" } }
            ]
          }
        ]
      },
      {
        "selector": "step4-body",
        "component": "Box",
        "componentProps": { "className": "space-y-4" },
        "children": [
          {
            "selector": "employment-section",
            "component": "Section",
            "componentProps": { "title": "Занятость", "className": "space-y-3" },
            "children": [
              { "model": "employmentStatus", "component": "RadioGroup", "componentProps": { "label": "Статус занятости", "options": "EMPLOYMENT_STATUSES", "testId": "employmentStatus" } }
            ]
          },
          {
            "selector": "employed-section",
            "component": "Section",
            "componentProps": { "title": "Работа по найму", "className": "space-y-3" },
            "children": [
              { "model": "companyName", "component": "Input", "componentProps": { "label": "Название компании", "placeholder": "Введите название", "testId": "companyName" } },
              { "model": "companyInn", "component": "InputMask", "componentProps": { "label": "ИНН компании", "mask": "9999999999", "placeholder": "1234567890", "testId": "companyInn" } },
              { "model": "companyPhone", "component": "InputMask", "componentProps": { "label": "Телефон компании", "mask": "+7 (999) 999-99-99", "placeholder": "+7 (___) ___-__-__", "testId": "companyPhone" } },
              { "model": "companyAddress", "component": "Input", "componentProps": { "label": "Адрес компании", "placeholder": "Полный адрес", "testId": "companyAddress" } },
              { "model": "position", "component": "Input", "componentProps": { "label": "Должность", "placeholder": "Ваша должность", "testId": "position" } }
            ]
          },
          {
            "selector": "experience-section",
            "component": "Section",
            "componentProps": { "title": "Стаж", "className": "space-y-3" },
            "children": [
              { "model": "workExperienceTotal", "component": "Input", "componentProps": { "label": "Общий стаж работы (месяцев)", "type": "number", "placeholder": "0", "testId": "workExperienceTotal" } },
              { "model": "workExperienceCurrent", "component": "Input", "componentProps": { "label": "Стаж на текущем месте (месяцев)", "type": "number", "placeholder": "0", "testId": "workExperienceCurrent" } }
            ]
          },
          {
            "selector": "income-section",
            "component": "Section",
            "componentProps": { "title": "Доход", "className": "space-y-3" },
            "children": [
              { "model": "monthlyIncome", "component": "Input", "componentProps": { "label": "Ежемесячный доход (₽)", "type": "number", "placeholder": "0", "testId": "monthlyIncome" } },
              { "model": "additionalIncome", "component": "Input", "componentProps": { "label": "Дополнительный доход (₽)", "type": "number", "placeholder": "0", "testId": "additionalIncome" } },
              { "model": "additionalIncomeSource", "component": "Input", "componentProps": { "label": "Источник дополнительного дохода", "placeholder": "Опишите источник", "testId": "additionalIncomeSource" } },
              { "model": "totalIncome", "component": "Input", "componentProps": { "label": "Общий доход (₽)", "type": "number", "readOnly": true, "testId": "totalIncome" } },
              { "model": "paymentToIncomeRatio", "component": "Input", "componentProps": { "label": "Процент платежа от дохода (%)", "type": "number", "readOnly": true, "testId": "paymentToIncomeRatio" } }
            ]
          },
          {
            "selector": "self-employed-section",
            "component": "Section",
            "componentProps": { "title": "ИП", "className": "space-y-3" },
            "children": [
              { "model": "businessType", "component": "Input", "componentProps": { "label": "Тип бизнеса", "placeholder": "ИП, ООО и т.д.", "testId": "businessType" } },
              { "model": "businessInn", "component": "InputMask", "componentProps": { "label": "ИНН ИП", "mask": "999999999999", "placeholder": "123456789012", "testId": "businessInn" } },
              { "model": "businessActivity", "component": "Textarea", "componentProps": { "label": "Вид деятельности", "placeholder": "Опишите вид деятельности", "rows": 3, "testId": "businessActivity" } }
            ]
          }
        ]
      },
      {
        "selector": "step5-body",
        "component": "Box",
        "componentProps": { "className": "space-y-4" },
        "children": [
          {
            "selector": "personal-extra-section",
            "component": "Section",
            "componentProps": { "title": "Личное", "className": "space-y-3" },
            "children": [
              { "model": "maritalStatus", "component": "RadioGroup", "componentProps": { "label": "Семейное положение", "options": "MARITAL_STATUSES", "testId": "maritalStatus" } },
              { "model": "dependents", "component": "Input", "componentProps": { "label": "Количество иждивенцев", "type": "number", "placeholder": "0", "testId": "dependents" } },
              { "model": "education", "component": "Select", "componentProps": { "label": "Образование", "placeholder": "Выберите уровень образования", "options": "EDUCATION_LEVELS", "testId": "education" } }
            ]
          },
          {
            "selector": "property-toggle-section",
            "component": "Section",
            "componentProps": { "title": "Имущество", "className": "space-y-3" },
            "children": [
              { "model": "hasProperty", "component": "Checkbox", "componentProps": { "label": "У меня есть имущество", "testId": "hasProperty" } }
            ]
          },
          {
            "selector": "properties-array-section",
            "component": "FormArraySection",
            "componentProps": {
              "title": "Имущество",
              "control": "properties",
              "addButtonLabel": "+ Добавить имущество",
              "removeButtonLabel": "Удалить",
              "emptyMessage": "Нажмите «Добавить имущество» для добавления записи",
              "initialValue": "PROPERTY_TEMPLATE",
              "itemLabel": "PROPERTY_ITEM_LABEL_FN",
              "itemComponent": {
                "$template": {
                  "component": "Box",
                  "componentProps": { "className": "space-y-3" },
                  "children": [
                    { "model": "type", "component": "Select", "componentProps": { "label": "Тип имущества", "options": "PROPERTY_TYPES", "testId": "propertyType" } },
                    { "model": "description", "component": "Textarea", "componentProps": { "label": "Описание", "rows": 2, "placeholder": "Опишите имущество", "testId": "propertyDescription" } },
                    { "model": "estimatedValue", "component": "Input", "componentProps": { "label": "Оценочная стоимость", "type": "number", "placeholder": "0", "testId": "propertyEstimatedValue" } },
                    { "model": "hasEncumbrance", "component": "Checkbox", "componentProps": { "label": "Имеется обременение (залог)", "testId": "propertyHasEncumbrance" } }
                  ]
                }
              }
            }
          },
          {
            "selector": "loans-toggle-section",
            "component": "Section",
            "componentProps": { "title": "Кредиты", "className": "space-y-3" },
            "children": [
              { "model": "hasExistingLoans", "component": "Checkbox", "componentProps": { "label": "У меня есть другие кредиты", "testId": "hasExistingLoans" } }
            ]
          },
          {
            "selector": "loans-array-section",
            "component": "FormArraySection",
            "componentProps": {
              "title": "Существующие кредиты",
              "control": "existingLoans",
              "addButtonLabel": "+ Добавить кредит",
              "removeButtonLabel": "Удалить",
              "emptyMessage": "Нажмите «Добавить кредит» для добавления записи",
              "initialValue": "EXISTING_LOAN_TEMPLATE",
              "itemLabel": "EXISTING_LOAN_ITEM_LABEL_FN",
              "itemComponent": {
                "$template": {
                  "component": "Box",
                  "componentProps": { "className": "space-y-3" },
                  "children": [
                    { "model": "bank", "component": "Input", "componentProps": { "label": "Банк", "placeholder": "Название банка", "testId": "loanBank" } },
                    { "model": "type", "component": "Input", "componentProps": { "label": "Тип кредита", "placeholder": "Тип кредита", "testId": "loanType" } },
                    { "model": "amount", "component": "Input", "componentProps": { "label": "Сумма кредита", "type": "number", "placeholder": "0", "testId": "loanAmount" } },
                    { "model": "remainingAmount", "component": "Input", "componentProps": { "label": "Остаток задолженности", "type": "number", "placeholder": "0", "testId": "loanRemainingAmount" } },
                    { "model": "monthlyPayment", "component": "Input", "componentProps": { "label": "Ежемесячный платёж", "type": "number", "placeholder": "0", "testId": "loanMonthlyPayment" } },
                    { "model": "maturityDate", "component": "Input", "componentProps": { "label": "Дата погашения", "type": "date", "testId": "loanMaturityDate" } }
                  ]
                }
              }
            }
          },
          {
            "selector": "co-borrower-toggle-section",
            "component": "Section",
            "componentProps": { "title": "Созаёмщики", "className": "space-y-3" },
            "children": [
              { "model": "hasCoBorrower", "component": "Checkbox", "componentProps": { "label": "Добавить созаёмщика", "testId": "hasCoBorrower" } }
            ]
          },
          {
            "selector": "co-borrowers-array-section",
            "component": "FormArraySection",
            "componentProps": {
              "title": "Созаёмщики",
              "control": "coBorrowers",
              "addButtonLabel": "+ Добавить созаёмщика",
              "removeButtonLabel": "Удалить",
              "emptyMessage": "Нажмите «Добавить созаёмщика» для добавления записи",
              "initialValue": "CO_BORROWER_TEMPLATE",
              "itemLabel": "CO_BORROWER_ITEM_LABEL_FN",
              "itemComponent": {
                "$template": {
                  "component": "Box",
                  "componentProps": { "className": "space-y-3" },
                  "children": [
                    { "model": "personalData.lastName", "component": "Input", "componentProps": { "label": "Фамилия", "placeholder": "Введите фамилию", "testId": "coBorrowerLastName" } },
                    { "model": "personalData.firstName", "component": "Input", "componentProps": { "label": "Имя", "placeholder": "Введите имя", "testId": "coBorrowerFirstName" } },
                    { "model": "personalData.middleName", "component": "Input", "componentProps": { "label": "Отчество", "placeholder": "Введите отчество", "testId": "coBorrowerMiddleName" } },
                    { "model": "personalData.birthDate", "component": "Input", "componentProps": { "label": "Дата рождения", "type": "date", "testId": "coBorrowerBirthDate" } },
                    { "model": "personalData.gender", "component": "RadioGroup", "componentProps": { "label": "Пол", "options": "GENDERS", "testId": "coBorrowerGender" } },
                    { "model": "personalData.birthPlace", "component": "Input", "componentProps": { "label": "Место рождения", "placeholder": "Введите место рождения", "testId": "coBorrowerBirthPlace" } },
                    { "model": "phone", "component": "InputMask", "componentProps": { "label": "Телефон", "mask": "+7 (999) 999-99-99", "placeholder": "+7 (___) ___-__-__", "testId": "coBorrowerPhone" } },
                    { "model": "email", "component": "Input", "componentProps": { "label": "Email", "type": "email", "placeholder": "example@mail.com", "testId": "coBorrowerEmail" } },
                    { "model": "relationship", "component": "Input", "componentProps": { "label": "Родство", "placeholder": "Укажите родство", "testId": "coBorrowerRelationship" } },
                    { "model": "monthlyIncome", "component": "Input", "componentProps": { "label": "Ежемесячный доход", "type": "number", "placeholder": "0", "testId": "coBorrowerMonthlyIncome" } }
                  ]
                }
              }
            }
          },
          {
            "selector": "co-borrowers-summary",
            "component": "Section",
            "componentProps": { "title": "Доход созаёмщиков", "className": "space-y-3" },
            "children": [
              { "model": "coBorrowersIncome", "component": "Input", "componentProps": { "label": "Доход созаёмщиков (₽)", "type": "number", "readOnly": true, "testId": "coBorrowersIncome" } }
            ]
          }
        ]
      },
      {
        "selector": "step6-body",
        "component": "Box",
        "componentProps": { "className": "space-y-4" },
        "children": [
          {
            "selector": "agreements-section",
            "component": "Section",
            "componentProps": { "title": "Согласия", "className": "space-y-3" },
            "children": [
              { "model": "agreePersonalData", "component": "Checkbox", "componentProps": { "label": "Согласие на обработку персональных данных", "testId": "agreePersonalData" } },
              { "model": "agreeCreditHistory", "component": "Checkbox", "componentProps": { "label": "Согласие на проверку кредитной истории", "testId": "agreeCreditHistory" } },
              { "model": "agreeMarketing", "component": "Checkbox", "componentProps": { "label": "Согласие на получение маркетинговых материалов", "testId": "agreeMarketing" } },
              { "model": "agreeTerms", "component": "Checkbox", "componentProps": { "label": "Согласие с условиями кредитования", "testId": "agreeTerms" } }
            ]
          },
          {
            "selector": "confirmation-section",
