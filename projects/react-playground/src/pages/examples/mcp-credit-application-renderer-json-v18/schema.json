{
  "version": "1.0",
  "steps": {
    "step1": {
      "component": "Box",
      "componentProps": { "className": "space-y-4" },
      "children": [
        {
          "component": "Section",
          "componentProps": { "title": "Основная информация о кредите" },
          "children": [
            { "model": "loanType", "component": "Select", "componentProps": { "label": "Тип кредита", "options": "LOAN_TYPES", "testId": "loanType" } },
            { "model": "loanAmount", "component": "Input", "componentProps": { "label": "Сумма кредита (₽)", "type": "number", "testId": "loanAmount" } },
            { "model": "loanTerm", "component": "Input", "componentProps": { "label": "Срок кредита (месяцев)", "type": "number", "testId": "loanTerm" } },
            { "model": "loanPurpose", "component": "Textarea", "componentProps": { "label": "Цель кредита", "testId": "loanPurpose" } }
          ]
        },
        {
          "selector": "mortgage-section",
          "component": "Section",
          "componentProps": { "title": "Параметры ипотеки" },
          "children": [
            { "model": "propertyValue", "component": "Input", "componentProps": { "label": "Стоимость недвижимости (₽)", "type": "number", "testId": "propertyValue" } },
            { "model": "initialPayment", "component": "Input", "componentProps": { "label": "Первоначальный взнос (₽)", "type": "number", "readOnly": true, "testId": "initialPayment" } }
          ]
        },
        {
          "selector": "car-section",
          "component": "Section",
          "componentProps": { "title": "Параметры автокредита" },
          "children": [
            { "model": "carBrand", "component": "Input", "componentProps": { "label": "Марка автомобиля", "testId": "carBrand" } },
            { "model": "carModel", "component": "Input", "componentProps": { "label": "Модель автомобиля", "testId": "carModel" } },
            { "model": "carYear", "component": "Input", "componentProps": { "label": "Год выпуска", "type": "number", "testId": "carYear" } },
            { "model": "carPrice", "component": "Input", "componentProps": { "label": "Стоимость автомобиля (₽)", "type": "number", "testId": "carPrice" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Расчёт" },
          "children": [
            { "model": "interestRate", "component": "Input", "componentProps": { "label": "Процентная ставка (%)", "type": "number", "readOnly": true, "testId": "interestRate" } },
            { "model": "monthlyPayment", "component": "Input", "componentProps": { "label": "Ежемесячный платеж (₽)", "type": "number", "readOnly": true, "testId": "monthlyPayment" } }
          ]
        }
      ]
    },
    "step2": {
      "component": "Box",
      "componentProps": { "className": "space-y-4" },
      "children": [
        {
          "component": "Section",
          "componentProps": { "title": "Личные данные" },
          "children": [
            { "model": "personalData.lastName", "component": "Input", "componentProps": { "label": "Фамилия", "testId": "personalData-lastName" } },
            { "model": "personalData.firstName", "component": "Input", "componentProps": { "label": "Имя", "testId": "personalData-firstName" } },
            { "model": "personalData.middleName", "component": "Input", "componentProps": { "label": "Отчество", "testId": "personalData-middleName" } },
            { "model": "personalData.birthDate", "component": "Input", "componentProps": { "label": "Дата рождения", "type": "date", "testId": "personalData-birthDate" } },
            { "model": "personalData.gender", "component": "RadioGroup", "componentProps": { "label": "Пол", "options": "GENDER_OPTIONS", "testId": "personalData-gender" } },
            { "model": "personalData.birthPlace", "component": "Input", "componentProps": { "label": "Место рождения", "testId": "personalData-birthPlace" } },
            { "model": "fullName", "component": "Input", "componentProps": { "label": "Полное имя", "readOnly": true, "testId": "fullName" } },
            { "model": "age", "component": "Input", "componentProps": { "label": "Возраст (лет)", "type": "number", "readOnly": true, "testId": "age" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Паспортные данные" },
          "children": [
            { "model": "passportData.series", "component": "InputMask", "componentProps": { "label": "Серия паспорта", "mask": "99 99", "testId": "passportData-series" } },
            { "model": "passportData.number", "component": "InputMask", "componentProps": { "label": "Номер паспорта", "mask": "999999", "testId": "passportData-number" } },
            { "model": "passportData.issueDate", "component": "Input", "componentProps": { "label": "Дата выдачи", "type": "date", "testId": "passportData-issueDate" } },
            { "model": "passportData.issuedBy", "component": "Input", "componentProps": { "label": "Кем выдан", "testId": "passportData-issuedBy" } },
            { "model": "passportData.departmentCode", "component": "InputMask", "componentProps": { "label": "Код подразделения", "mask": "999-999", "testId": "passportData-departmentCode" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Документы" },
          "children": [
            { "model": "inn", "component": "InputMask", "componentProps": { "label": "ИНН", "mask": "999999999999", "testId": "inn" } },
            { "model": "snils", "component": "InputMask", "componentProps": { "label": "СНИЛС", "mask": "999-999-999 99", "testId": "snils" } }
          ]
        }
      ]
    },
    "step3": {
      "component": "Box",
      "componentProps": { "className": "space-y-4" },
      "children": [
        {
          "component": "Section",
          "componentProps": { "title": "Телефоны" },
          "children": [
            { "model": "phoneMain", "component": "InputMask", "componentProps": { "label": "Основной телефон", "mask": "+7 (999) 999-99-99", "testId": "phoneMain" } },
            { "model": "phoneAdditional", "component": "InputMask", "componentProps": { "label": "Дополнительный телефон", "mask": "+7 (999) 999-99-99", "testId": "phoneAdditional" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Email" },
          "children": [
            { "model": "email", "component": "Input", "componentProps": { "label": "Email", "type": "email", "testId": "email" } },
            { "model": "emailAdditional", "component": "Input", "componentProps": { "label": "Дополнительный email", "type": "email", "testId": "emailAdditional" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Адрес регистрации" },
          "children": [
            { "model": "registrationAddress.region", "component": "Input", "componentProps": { "label": "Регион", "testId": "registrationAddress-region" } },
            { "model": "registrationAddress.city", "component": "Input", "componentProps": { "label": "Город", "testId": "registrationAddress-city" } },
            { "model": "registrationAddress.street", "component": "Input", "componentProps": { "label": "Улица", "testId": "registrationAddress-street" } },
            { "model": "registrationAddress.house", "component": "Input", "componentProps": { "label": "Дом", "testId": "registrationAddress-house" } },
            { "model": "registrationAddress.apartment", "component": "Input", "componentProps": { "label": "Квартира", "testId": "registrationAddress-apartment" } },
            { "model": "registrationAddress.postalCode", "component": "InputMask", "componentProps": { "label": "Индекс", "mask": "999999", "testId": "registrationAddress-postalCode" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Адрес проживания" },
          "children": [
            { "model": "sameAsRegistration", "component": "Checkbox", "componentProps": { "label": "Адрес проживания совпадает с адресом регистрации", "testId": "sameAsRegistration" } },
            {
              "selector": "residence-address-section",
              "component": "Box",
              "componentProps": { "className": "space-y-3" },
              "children": [
                { "model": "residenceAddress.region", "component": "Input", "componentProps": { "label": "Регион", "testId": "residenceAddress-region" } },
                { "model": "residenceAddress.city", "component": "Input", "componentProps": { "label": "Город", "testId": "residenceAddress-city" } },
                { "model": "residenceAddress.street", "component": "Input", "componentProps": { "label": "Улица", "testId": "residenceAddress-street" } },
                { "model": "residenceAddress.house", "component": "Input", "componentProps": { "label": "Дом", "testId": "residenceAddress-house" } },
                { "model": "residenceAddress.apartment", "component": "Input", "componentProps": { "label": "Квартира", "testId": "residenceAddress-apartment" } },
                { "model": "residenceAddress.postalCode", "component": "InputMask", "componentProps": { "label": "Индекс", "mask": "999999", "testId": "residenceAddress-postalCode" } }
              ]
            }
          ]
        }
      ]
    },
    "step4": {
      "component": "Box",
      "componentProps": { "className": "space-y-4" },
      "children": [
        {
          "component": "Section",
          "componentProps": { "title": "Занятость" },
          "children": [
            { "model": "employmentStatus", "component": "RadioGroup", "componentProps": { "label": "Статус занятости", "options": "EMPLOYMENT_STATUS_OPTIONS", "testId": "employmentStatus" } }
          ]
        },
        {
          "selector": "employed-section",
          "component": "Section",
          "componentProps": { "title": "Работа по найму" },
          "children": [
            { "model": "companyName", "component": "Input", "componentProps": { "label": "Название компании", "testId": "companyName" } },
            { "model": "companyInn", "component": "InputMask", "componentProps": { "label": "ИНН компании", "mask": "9999999999", "testId": "companyInn" } },
            { "model": "companyPhone", "component": "InputMask", "componentProps": { "label": "Телефон компании", "mask": "+7 (999) 999-99-99", "testId": "companyPhone" } },
            { "model": "companyAddress", "component": "Input", "componentProps": { "label": "Адрес компании", "testId": "companyAddress" } },
            { "model": "position", "component": "Input", "componentProps": { "label": "Должность", "testId": "position" } }
          ]
        },
        {
          "selector": "self-employed-section",
          "component": "Section",
          "componentProps": { "title": "Индивидуальный предприниматель" },
          "children": [
            { "model": "businessType", "component": "Input", "componentProps": { "label": "Тип бизнеса", "testId": "businessType" } },
            { "model": "businessInn", "component": "InputMask", "componentProps": { "label": "ИНН ИП", "mask": "999999999999", "testId": "businessInn" } },
            { "model": "businessActivity", "component": "Textarea", "componentProps": { "label": "Вид деятельности", "testId": "businessActivity" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Стаж" },
          "children": [
            { "model": "workExperienceTotal", "component": "Input", "componentProps": { "label": "Общий стаж работы (месяцев)", "type": "number", "testId": "workExperienceTotal" } },
            { "model": "workExperienceCurrent", "component": "Input", "componentProps": { "label": "Стаж на текущем месте (месяцев)", "type": "number", "testId": "workExperienceCurrent" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Доход" },
          "children": [
            { "model": "monthlyIncome", "component": "Input", "componentProps": { "label": "Ежемесячный доход (₽)", "type": "number", "testId": "monthlyIncome" } },
            { "model": "additionalIncome", "component": "Input", "componentProps": { "label": "Дополнительный доход (₽)", "type": "number", "testId": "additionalIncome" } },
            { "model": "additionalIncomeSource", "component": "Input", "componentProps": { "label": "Источник дополнительного дохода", "testId": "additionalIncomeSource" } },
            { "model": "totalIncome", "component": "Input", "componentProps": { "label": "Общий доход (₽)", "type": "number", "readOnly": true, "testId": "totalIncome" } },
            { "model": "paymentToIncomeRatio", "component": "Input", "componentProps": { "label": "Процент платежа от дохода (%)", "type": "number", "readOnly": true, "testId": "paymentToIncomeRatio" } }
          ]
        }
      ]
    },
    "step5": {
      "component": "Box",
      "componentProps": { "className": "space-y-4" },
      "children": [
        {
          "component": "Section",
          "componentProps": { "title": "Личное" },
          "children": [
            { "model": "maritalStatus", "component": "RadioGroup", "componentProps": { "label": "Семейное положение", "options": "MARITAL_STATUS_OPTIONS", "testId": "maritalStatus" } },
            { "model": "dependents", "component": "Input", "componentProps": { "label": "Количество иждивенцев", "type": "number", "testId": "dependents" } },
            { "model": "education", "component": "Select", "componentProps": { "label": "Образование", "options": "EDUCATION_OPTIONS", "testId": "education" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Имущество" },
          "children": [
            { "model": "hasProperty", "component": "Checkbox", "componentProps": { "label": "У меня есть имущество", "testId": "hasProperty" } },
            {
              "selector": "properties-section",
              "component": "FormArraySection",
              "componentProps": {
                "control": "properties",
                "title": "Список имущества",
                "addButtonLabel": "+ Добавить имущество",
                "removeButtonLabel": "Удалить",
                "initialValue": "PROPERTY_TEMPLATE",
                "itemComponent": {
                  "$template": {
                    "component": "Box",
                    "componentProps": { "className": "space-y-3" },
                    "children": [
                      { "model": "type", "component": "Select", "componentProps": { "label": "Тип имущества", "options": "PROPERTY_TYPES", "testId": "type" } },
                      { "model": "description", "component": "Textarea", "componentProps": { "label": "Описание", "testId": "description" } },
                      { "model": "estimatedValue", "component": "Input", "componentProps": { "label": "Оценочная стоимость", "type": "number", "testId": "estimatedValue" } },
                      { "model": "hasEncumbrance", "component": "Checkbox", "componentProps": { "label": "Имеется обременение (залог)", "testId": "hasEncumbrance" } }
                    ]
                  }
                }
              }
            }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Кредиты" },
          "children": [
            { "model": "hasExistingLoans", "component": "Checkbox", "componentProps": { "label": "У меня есть другие кредиты", "testId": "hasExistingLoans" } },
            {
              "selector": "existing-loans-section",
              "component": "FormArraySection",
              "componentProps": {
                "control": "existingLoans",
                "title": "Список кредитов",
                "addButtonLabel": "+ Добавить кредит",
                "removeButtonLabel": "Удалить",
                "initialValue": "EXISTING_LOAN_TEMPLATE",
                "itemComponent": {
                  "$template": {
                    "component": "Box",
                    "componentProps": { "className": "space-y-3" },
                    "children": [
                      { "model": "bank", "component": "Input", "componentProps": { "label": "Банк", "testId": "bank" } },
                      { "model": "type", "component": "Input", "componentProps": { "label": "Тип кредита", "testId": "type" } },
                      { "model": "amount", "component": "Input", "componentProps": { "label": "Сумма кредита", "type": "number", "testId": "amount" } },
                      { "model": "remainingAmount", "component": "Input", "componentProps": { "label": "Остаток задолженности", "type": "number", "testId": "remainingAmount" } },
                      { "model": "monthlyPayment", "component": "Input", "componentProps": { "label": "Ежемесячный платеж", "type": "number", "testId": "monthlyPayment" } },
                      { "model": "maturityDate", "component": "Input", "componentProps": { "label": "Дата погашения", "type": "date", "testId": "maturityDate" } }
                    ]
                  }
                }
              }
            }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Созаемщики" },
          "children": [
            { "model": "hasCoBorrower", "component": "Checkbox", "componentProps": { "label": "Добавить созаемщика", "testId": "hasCoBorrower" } },
            {
              "selector": "co-borrowers-section",
              "component": "FormArraySection",
              "componentProps": {
                "control": "coBorrowers",
                "title": "Список созаемщиков",
                "addButtonLabel": "+ Добавить созаемщика",
                "removeButtonLabel": "Удалить",
                "initialValue": "CO_BORROWER_TEMPLATE",
                "itemComponent": {
                  "$template": {
                    "component": "Box",
                    "componentProps": { "className": "space-y-3" },
                    "children": [
                      { "model": "personalData.lastName", "component": "Input", "componentProps": { "label": "Фамилия", "testId": "personalData-lastName" } },
                      { "model": "personalData.firstName", "component": "Input", "componentProps": { "label": "Имя", "testId": "personalData-firstName" } },
                      { "model": "personalData.middleName", "component": "Input", "componentProps": { "label": "Отчество", "testId": "personalData-middleName" } },
                      { "model": "personalData.birthDate", "component": "Input", "componentProps": { "label": "Дата рождения", "type": "date", "testId": "personalData-birthDate" } },
                      { "model": "personalData.gender", "component": "RadioGroup", "componentProps": { "label": "Пол", "options": "GENDER_OPTIONS", "testId": "personalData-gender" } },
                      { "model": "personalData.birthPlace", "component": "Input", "componentProps": { "label": "Место рождения", "testId": "personalData-birthPlace" } },
                      { "model": "phone", "component": "InputMask", "componentProps": { "label": "Телефон", "mask": "+7 (999) 999-99-99", "testId": "phone" } },
                      { "model": "email", "component": "Input", "componentProps": { "label": "Email", "type": "email", "testId": "email" } },
                      { "model": "relationship", "component": "Input", "componentProps": { "label": "Родство", "testId": "relationship" } },
                      { "model": "monthlyIncome", "component": "Input", "componentProps": { "label": "Ежемесячный доход", "type": "number", "testId": "monthlyIncome" } }
                    ]
                  }
                }
              }
            },
            { "model": "coBorrowersIncome", "component": "Input", "componentProps": { "label": "Доход созаемщиков (₽)", "type": "number", "readOnly": true, "testId": "coBorrowersIncome" } }
          ]
        }
      ]
    },
    "step6": {
      "component": "Box",
      "componentProps": { "className": "space-y-4" },
      "children": [
        {
          "component": "Section",
          "componentProps": { "title": "Согласия" },
          "children": [
            { "model": "agreePersonalData", "component": "Checkbox", "componentProps": { "label": "Согласие на обработку персональных данных", "testId": "agreePersonalData" } },
            { "model": "agreeCreditHistory", "component": "Checkbox", "componentProps": { "label": "Согласие на проверку кредитной истории", "testId": "agreeCreditHistory" } },
            { "model": "agreeMarketing", "component": "Checkbox", "componentProps": { "label": "Согласие на получение маркетинговых материалов", "testId": "agreeMarketing" } },
            { "model": "agreeTerms", "component": "Checkbox", "componentProps": { "label": "Согласие с условиями кредитования", "testId": "agreeTerms" } }
          ]
        },
        {
          "component": "Section",
          "componentProps": { "title": "Подтверждение" },
          "children": [
            { "model": "confirmAccuracy", "component": "Checkbox", "componentProps": { "label": "Подтверждаю точность введенных данных", "testId": "confirmAccuracy" } },
            { "model": "electronicSignature", "component": "InputMask", "componentProps": { "label": "Код подтверждения из СМС", "mask": "999999", "testId": "electronicSignature" } }
          ]
        }
      ]
    }
  }
}
